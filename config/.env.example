# =============================================================================
# AutoCoinTrade - Environment Variables Template
# =============================================================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# 중요: .env 파일은 절대 Git에 커밋하지 마세요!

# -----------------------------------------------------------------------------
# 거래소 API 설정
# -----------------------------------------------------------------------------
# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET_API_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_binance_testnet_api_secret_here

# Upbit (한국)
UPBIT_ACCESS_KEY=your_upbit_access_key_here
UPBIT_SECRET_KEY=your_upbit_secret_key_here

# Bithumb (한국)
BITHUMB_API_KEY=your_bithumb_api_key_here
BITHUMB_SECRET_KEY=your_bithumb_secret_key_here

# -----------------------------------------------------------------------------
# 알림 설정
# -----------------------------------------------------------------------------
# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# -----------------------------------------------------------------------------
# 데이터베이스 설정
# -----------------------------------------------------------------------------
# PostgreSQL (선택)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autocointrade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Redis (선택)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# -----------------------------------------------------------------------------
# 실행 모드 설정
# -----------------------------------------------------------------------------
# true = 실제 거래, false = 시뮬레이션
DRY_RUN=false

# -----------------------------------------------------------------------------
# 로깅 설정
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Gemini AI 설정
# -----------------------------------------------------------------------------
# Gemini API 키 (https://aistudio.google.com/app/apikey 에서 발급)
GEMINI_API_KEY=your_gemini_api_key_here
# 또는
# GOOGLE_AI_API_KEY=your_google_ai_api_key_here
